{
  "identifier": "default",
  "description": "Default capabilities for dnjplayer",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "fs:default",
    "notification:default",
    "libmpv:default"
  ]
}
