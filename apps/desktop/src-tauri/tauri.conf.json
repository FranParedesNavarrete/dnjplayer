{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "dnjplayer",
  "version": "1.1.0",
  "identifier": "com.dnjplayer.app",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "dnjplayer",
        "width": 1280,
        "height": 720,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:4443 ipc: tauri:; img-src 'self' data:; media-src 'self' http://127.0.0.1:4443; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "lib/**/*",
      "../static/shaders/**/*"
    ]
  }
}